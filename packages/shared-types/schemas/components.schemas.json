{
  "AccessPoint": {
    "additionalProperties": false,
    "description": "Normalized wireless access point snapshot.",
    "properties": {
      "band": {
        "anyOf": [
          {
            "maxLength": 16,
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Band"
      },
      "bssid": {
        "pattern": "^[0-9A-Fa-f]{2}(:[0-9A-Fa-f]{2}){5}$",
        "title": "Bssid",
        "type": "string"
      },
      "channel": {
        "anyOf": [
          {
            "maximum": 196.0,
            "minimum": 1.0,
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Channel"
      },
      "encryption": {
        "items": {
          "type": "string"
        },
        "title": "Encryption",
        "type": "array"
      },
      "first_seen": {
        "format": "date-time",
        "title": "First Seen",
        "type": "string"
      },
      "flags": {
        "items": {
          "type": "string"
        },
        "title": "Flags",
        "type": "array"
      },
      "last_seen": {
        "format": "date-time",
        "title": "Last Seen",
        "type": "string"
      },
      "latitude": {
        "anyOf": [
          {
            "maximum": 90.0,
            "minimum": -90.0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "title": "Latitude"
      },
      "location_source": {
        "anyOf": [
          {
            "enum": [
              "sensor_gps",
              "wigle",
              "manual"
            ],
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Location Source"
      },
      "longitude": {
        "anyOf": [
          {
            "maximum": 180.0,
            "minimum": -180.0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "title": "Longitude"
      },
      "signal_history": {
        "items": {
          "$ref": "#/components/schemas/SignalSample"
        },
        "title": "Signal History",
        "type": "array"
      },
      "ssid": {
        "default": "",
        "maxLength": 128,
        "title": "Ssid",
        "type": "string"
      },
      "vendor_oui": {
        "anyOf": [
          {
            "maxLength": 128,
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Vendor Oui"
      }
    },
    "required": [
      "bssid"
    ],
    "title": "AccessPoint",
    "type": "object"
  },
