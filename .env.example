CHEEKY_PONY_ENV=dev
CHEEKY_PONY_LAB_MODE=false
CHEEKY_PONY_MONGO_DSN=mongodb://localhost:27017
CHEEKY_PONY_MONGO_DB=cheeky_pony
CHEEKY_PONY_REDIS_DSN=redis://localhost:6379/0
CHEEKY_PONY_JWT_SECRET=replace-with-32-plus-random-bytes
CHEEKY_PONY_COOKIE_SECURE=false
CHEEKY_PONY_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CHEEKY_PONY_BOOTSTRAP_TOKEN=replace-with-one-time-random-token
CHEEKY_PONY_SEED_ADMIN_EMAIL=admin@example.com
CHEEKY_PONY_SEED_ADMIN_PASSWORD=change-me-now
CHEEKY_PONY_REPORT_DOWNLOAD_TOKEN_MINUTES=15
# PCAP settings bound operator-controlled binary input and tshark subprocess risk.
CHEEKY_PONY_PCAP_MAX_UPLOAD_MB=100
CHEEKY_PONY_PCAP_INTERNAL_HOSTNAME_SUFFIXES=.local,.internal,.corp
CHEEKY_PONY_TSHARK_MIN_VERSION=4.2.0
CHEEKY_PONY_TSHARK_PATH=tshark
CHEEKY_PONY_TSHARK_STDOUT_MAX_MB=50
CHEEKY_PONY_TSHARK_TIMEOUT_SECONDS=90
CHEEKY_PONY_TOTP_RECENT_MINUTES=15
CHEEKY_PONY_LABEL_CONFIDENCE_THRESHOLD=0.6
# LLM insights are opt-in. Prompts are redacted and only hashes are audited.
CHEEKY_PONY_LLM_ENABLED=false
CHEEKY_PONY_LLM_API_BASE_URL=https://api.openai.com/v1
CHEEKY_PONY_LLM_API_KEY=replace-with-openai-compatible-api-key
CHEEKY_PONY_LLM_MODEL=gpt-4o-mini
# 0 means unlimited, intended for local/private models without per-call billing.
CHEEKY_PONY_LLM_BUDGET_USD_MONTHLY=0
CHEEKY_PONY_LLM_REDACT_SSID=false
CHEEKY_PONY_LLM_REDACT_VENDOR=false
CHEEKY_PONY_LLM_REQUEST_TIMEOUT_SECONDS=30
CHEEKY_PONY_LLM_MAX_RESPONSE_TOKENS=500
CHEEKY_PONY_SENSOR_GATEWAY_HEADER_SECRET=replace-with-32-plus-random-bytes
